{
	"name": "mcu-watchlist-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"check": "astro check",
		"check:watch": "astro check --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test --pass-with-no-tests"
	},
	"overrides": {
		"cookie": "0.7.2"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^20",
		"@vitest/browser-playwright": "^4.1.8",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-svelte": "^4.1.0",
		"sharp": "^0.34.4",
		"svelte": "^5.56.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@astrojs/svelte": "^9.0.0",
		"astro": "^7.0.2",
		"nanostores": "^1.3.0"
	},
	"volta": {
		"node": "22.22.1"
	}
}
