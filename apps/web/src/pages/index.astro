---
// The prerendered "/" timeline view (replaces routes/+page.svelte): the catalog hero, the
// stats panel, the filter/search toolbar, and the era-grouped timeline of every catalog
// item.
//
// The hero markup (eyebrow/h1/intro) is static, plain .astro markup -- no reactivity needed
// there, so it is rendered directly here rather than as a Svelte island.
//
// FilterBar/SearchInput/EssentialToggle/StatsBar/TimelineView are mounted as independent
// fine-grained islands, each reading/writing the shared `filtersStore`/`progressStore`
// nanostore singletons directly (lib/state/filters.ts, lib/state/progress.ts). All but
// TimelineView sit above the fold and use client:load; TimelineView is the heaviest island
// and starts below the fold, so it uses client:visible to defer its hydration cost until it
// scrolls into view.
// instead of receiving props/callbacks from one parent component's script block -- unlike
// +page.svelte, a single Svelte component's <script>, an .astro page has no client-side
// script of its own that could hold that wiring, and separately mounted islands don't share
// a closure. nanostores atoms are plain shared singletons, so every island reading the same
// store re-renders independently when it changes; this is more idiomatic Astro than
// introducing a new wrapper Svelte component that doesn't exist in the current codebase
// (see docs/superpowers/specs/2026-06-23-astro-migration-design.md).
//
// The full catalog (`items`) is static, build-time data (lib/data/items.ts), imported here
// and passed into the StatsBar/TimelineView islands, which each recompute their own
// `filtersStore.stats`/`visibleItems` slice from it -- this is the "zero-JS catalog"
// prerendering goal: every item is already in the prerendered HTML before any store
// hydration happens client-side. Only `progress` (and therefore which items show as
// watched/skipped) updates after hydration.
//
// `totalEpisodesByItemId` (marvel-s4b) is the same kind of static, build-time-derived prop:
// it is computed below from the `episodes` Content Layer collection, which only the
// frontmatter here can read, and threaded into TimelineView -> EraGroup -> ItemCard so each
// series card can render its "X/N" episode progress pill without any client-side fetch.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { items } from '../lib/data/items';
import { getSeasonNumber } from '../lib/data/mediaMetadata/itemSeason';
import FilterBar from '../lib/components/common/FilterBar.svelte';
import SearchInput from '../lib/components/common/SearchInput.svelte';
import EssentialToggle from '../lib/components/common/EssentialToggle.svelte';
import StatsBar from '../lib/components/common/StatsBar.svelte';
import TimelineView from '../lib/components/timeline/TimelineView.svelte';

// Per-item baked episode counts (marvel-s4b), keyed by catalog item id, for series cards'
// "X/N" progress pill. The `episodes` Content Layer collection (content.config.ts) is keyed
// by `imdbId-s{season}` (matching episodeInfoLoader.ts), not by catalog item id, so this maps
// from the collection's key back to the item id every series in the catalog actually uses --
// the same lookup [id].astro does for its own episodes prop, but read-only-once here since
// TimelineView/ItemCard are islands and can't read the collection themselves (Astro Content
// Layer is only readable from .astro frontmatter). A series with no baked entry (unreleased,
// or no snapshot yet) is simply absent from the map; ItemCard treats a missing/zero count as
// "render nothing" rather than a broken "X/undefined" pill.
const episodeEntries = await getCollection('episodes');
const episodesByKey = new Map(episodeEntries.map((entry) => [entry.id, entry.data]));

const totalEpisodesByItemId: Record<string, number> = {};
for (const item of items) {
	if (item.type !== 'series') {
		continue;
	}

	const episodesKey = `${item.imdbId}-s${getSeasonNumber(item.id)}`;
	const entry = episodesByKey.get(episodesKey);

	if (entry) {
		totalEpisodesByItemId[item.id] = entry.totalCount;
	}
}
---

<BaseLayout>
	<Fragment slot="head">
		<title>Marvel Chronological Watchlist</title>
		<meta
			name="description"
			content="Browse the MCU in chronological order, sign in to track which movies, series, shorts and specials you've watched, and see what to watch next."
		/>
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://mcu-watchlist.codequest.nl/" />
		<meta property="og:title" content="Marvel Chronological Watchlist" />
		<meta
			property="og:description"
			content="Browse the MCU in chronological order, sign in to track which movies, series, shorts and specials you've watched, and see what to watch next."
		/>
		<link rel="canonical" href="https://mcu-watchlist.codequest.nl/" />
	</Fragment>

	<section class="hero">
		<div>
			<div class="eyebrow">MCU movies, series, shorts and specials</div>
			<h1>Marvel Chronological Watchlist</h1>
			<p class="intro">
				Follow the MCU timeline order, mark what you have watched, and pick up where you left off. Sign in with email to
				save your progress to your account.
			</p>
		</div>

		<StatsBar items={items} client:load />
	</section>

	<section class="toolbar" aria-label="Watchlist controls">
		<div class="toolbar-row">
			<EssentialToggle client:load />
		</div>

		<div class="toolbar-row">
			<FilterBar client:load />

			<SearchInput client:load />
		</div>
	</section>

	<TimelineView items={items} totalEpisodesByItemId={totalEpisodesByItemId} client:visible />
</BaseLayout>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 340px;
		gap: 28px;
		align-items: end;
		margin-bottom: 24px;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		width: fit-content;
		margin-bottom: 14px;
		padding: 7px 11px;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.06);
		color: var(--muted);
		font-size: 13px;
		letter-spacing: 0.02em;
	}

	.eyebrow::before {
		content: '';
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 22px var(--accent);
	}

	h1 {
		max-width: 780px;
		margin: 0;
		font-size: clamp(38px, 7vw, 82px);
		line-height: 0.94;
		letter-spacing: -0.065em;
	}

	.intro {
		max-width: 700px;
		margin: 18px 0 0;
		color: var(--muted);
		font-size: 17px;
		line-height: 1.6;
	}

	.toolbar {
		position: sticky;
		top: 12px;
		z-index: 3;
		display: grid;
		gap: 12px;
		margin: 28px 0 18px;
		padding: 12px;
		border: 1px solid var(--border);
		border-radius: 26px;
		background: rgba(12, 16, 32, 0.78);
		backdrop-filter: blur(18px);
	}

	.toolbar-row {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		align-items: center;
		justify-content: space-between;
	}

	@media (max-width: 820px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.toolbar {
			position: static;
		}
	}
</style>
